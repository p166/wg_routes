# Telegram Bot Token
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# SSH Configuration
SSH_HOST=s1.example.com
SSH_PORT=22
SSH_USER=wg_bot
SSH_KEY_PATH=/home/user/.ssh/id_rsa

# S1 paths
S1_WG_DESTINATIONS_PATH=wg_destinations.txt
S1_WG_V6_ROUTES_PATH=wg_v6_routes.txt
S1_UPDATE_SCRIPT_PATH=/path/to/update_allowedips_awg.sh

# DNS resolver
DNS_TIMEOUT=5
DNS_SERVER=8.8.8.8

# Admin user (optional, for security)
ADMIN_USER_ID=YOUR_TELEGRAM_ID_HERE
